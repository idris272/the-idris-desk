// ═══════════════════════════════════════════════════════════════════════════
// firestore/firestore.rules
// THE JAAGA DESK — Firestore Security Rules
//
// These rules run on Google's servers and protect your database.
// Without proper rules anyone could read/write your entire database.
//
// DEPLOY: firebase deploy --only firestore:rules
// ═══════════════════════════════════════════════════════════════════════════

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── HELPER FUNCTIONS ────────────────────────────────────────────────
    
    // Is the request coming from a logged-in user?
    function isSignedIn() {
      return request.auth != null;
    }

    // Is the requesting user the owner of this document?
    function isOwner(uid) {
      return request.auth.uid == uid;
    }

    // Fetch the requesting user's role from Firestore
    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    // Is the user an admin?
    function isAdmin() {
      return isSignedIn() && getUserRole() == 'admin';
    }

    // Is the user an editor or admin?
    function isEditorOrAbove() {
      return isSignedIn() && getUserRole() in ['admin', 'editor'];
    }

    // Is the user an author, editor, or admin?
    function isAuthorOrAbove() {
      return isSignedIn() && getUserRole() in ['admin', 'editor', 'author'];
    }

    // ─── POSTS ───────────────────────────────────────────────────────────
    match /posts/{postId} {
      // Anyone (logged in or not) can read published posts
      allow read: if resource.data.status == 'published' 
                  || isAdmin() 
                  || isEditorOrAbove()
                  || (isSignedIn() && resource.data.author == request.auth.uid);

      // Authors can create posts
      allow create: if isAuthorOrAbove()
                    && request.resource.data.author == request.auth.uid
                    && request.resource.data.title.size() > 0
                    && request.resource.data.content.size() > 0;

      // Authors can only edit their own posts; editors/admins can edit any
      allow update: if (isAuthorOrAbove() && resource.data.author == request.auth.uid)
                    || isEditorOrAbove();

      // Only admins and editors can delete
      allow delete: if isEditorOrAbove();
    }

    // ─── USERS ───────────────────────────────────────────────────────────
    match /users/{uid} {
      // Users can read their own profile; admins can read all
      allow read: if isOwner(uid) || isAdmin();

      // Users can only create their own profile document
      allow create: if isOwner(uid);

      // Users can update their own profile (but NOT their own role field)
      // Only admins can change roles
      allow update: if (isOwner(uid) && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role']))
                    || isAdmin();

      // Nobody can delete user documents through the client
      allow delete: if false;
    }

    // ─── COMMENTS ────────────────────────────────────────────────────────
    match /comments/{commentId} {
      // Anyone can read approved comments
      allow read: if resource.data.approved == true || isEditorOrAbove();

      // Signed-in users and guests can post comments
      // (guest comments have author == 'guest')
      allow create: if request.resource.data.content.size() > 0
                    && request.resource.data.content.size() < 2000
                    && request.resource.data.postId is string;

      // Only editors/admins can delete or moderate comments
      allow update: if isEditorOrAbove();
      allow delete: if isEditorOrAbove();
    }

    // ─── LIKES ───────────────────────────────────────────────────────────
    match /likes/{likeId} {
      // Anyone can read likes
      allow read: if true;

      // Only signed-in users can like, and they can only like as themselves
      // The likeId format is: {postId}_{uid}
      allow create: if isSignedIn() 
                    && likeId.matches('^[^_]+_' + request.auth.uid + '$');

      // Users can only delete their own likes
      allow delete: if isSignedIn() 
                    && likeId.matches('^[^_]+_' + request.auth.uid + '$');

      allow update: if false; // likes are create/delete only
    }

    // ─── BOOKMARKS ───────────────────────────────────────────────────────
    match /bookmarks/{uid} {
      // Users can only read/write their own bookmarks
      allow read, write: if isOwner(uid);
    }

    // ─── SUBSCRIBERS ─────────────────────────────────────────────────────
    match /subscribers/{email} {
      // Admins can read all subscribers
      allow read: if isAdmin();

      // Anyone can create (subscribe) — one document per email address
      allow create: if request.resource.data.email is string
                    && request.resource.data.email.matches('.*@.*\\..*');

      // Only the Cloud Function (admin SDK) can update (mark verified)
      // Client can't mark themselves as verified — prevents fraud
      allow update: if false;

      // Only admins can delete subscribers
      allow delete: if isAdmin();
    }

    // ─── CATEGORIES ──────────────────────────────────────────────────────
    match /categories/{catId} {
      // Anyone can read categories
      allow read: if true;

      // Only admins can create/edit/delete categories
      allow write: if isAdmin();
    }

    // ─── ACTIVITY LOG ─────────────────────────────────────────────────────
    match /activity/{docId} {
      // Only admins can read activity log
      allow read: if isAdmin();

      // Cloud Functions write to this — client writes are blocked
      allow write: if false;
    }

    // ─── READ HISTORY ─────────────────────────────────────────────────────
    match /readHistory/{uid} {
      allow read, write: if isOwner(uid);
    }
  }
}
