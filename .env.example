# ═══════════════════════════════════════════════════════════════════════════
# .env.example — The Jaaga Desk
# Copy this file to .env.local and fill in your real values.
# NEVER commit .env.local to GitHub.
# Add these same values in Vercel → Project Settings → Environment Variables
#
# FIREBASE KEYS — from console.firebase.google.com
#   Project Settings → Your apps → Web app → firebaseConfig
# ═══════════════════════════════════════════════════════════════════════════

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# CLOUDINARY KEYS — from cloudinary.com (free, no credit card)
#   Dashboard → Cloud name (shown at top of page)
#   Settings → Upload → Upload presets → Add preset → set to Unsigned → save
VITE_CLOUDINARY_CLOUD_NAME=
VITE_CLOUDINARY_UPLOAD_PRESET=
