# ═══════════════════════════════════════════════════════════════════════════
# .env.example — The Jaaga Desk
# Copy this file to .env.local and fill in your real values.
# NEVER commit .env.local to GitHub.
# Add these same values in Vercel → Project Settings → Environment Variables
#
# FIREBASE KEYS — from console.firebase.google.com
#   Project Settings → Your apps → Web app → firebaseConfig
# ═══════════════════════════════════════════════════════════════════════════

VITE_FIREBASE_API_KEY=AIzaSy-PASTE-YOUR-KEY-HERE
VITE_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789012
VITE_FIREBASE_APP_ID=1:123456789012:web:abcdef1234567890

# CLOUDINARY KEYS — from cloudinary.com (free, no credit card)
#   Dashboard → Cloud name (shown at top of page)
#   Settings → Upload → Upload presets → Add preset → set to Unsigned → save
VITE_CLOUDINARY_CLOUD_NAME=your-cloud-name
VITE_CLOUDINARY_UPLOAD_PRESET=your-upload-preset-name
